# OpenClaw KakaoTalk Channel Plugin 설정
# 이 파일을 .env로 복사하고 값을 채워주세요

# ── OpenClaw Gateway ──────────────────────────────────────────────────────
# OpenClaw Gateway URL (기본: 로컬 18789 포트)
OPENCLAW_GATEWAY_URL=http://localhost:18789

# OpenClaw Gateway 인증 토큰 (openclaw.json의 gateway.token 값)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ── 릴레이 서버 보안 ──────────────────────────────────────────────────────
# Admin API 보호 토큰 (비워두면 Admin API 인증 없음)
RELAY_TOKEN=your-relay-token-here

# 카카오 i 오픈빌더 채널 시크릿 (선택 — 웹훅 서명 검증용)
KAKAO_CHANNEL_SECRET=

# ── 채널 설정 ──────────────────────────────────────────────────────────────
# DM 정책: pairing | open | allowlist | disabled
DM_POLICY=pairing

# allowlist 모드일 때 허용할 카카오 사용자 ID (쉼표 구분)
ALLOW_FROM=

# OpenClaw 세션 ID 접두사
SESSION_PREFIX=kakao

# OpenClaw 응답 대기 최대 시간 (초) — 카카오 제한: 실질적으로 5초
RESPONSE_TIMEOUT=25
