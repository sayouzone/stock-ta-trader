# ╔═══════════════════════════════════════════════════════╗
# ║  Stock TA Trader — Environment Configuration         ║
# ║  .env.example → .env 로 복사 후 값을 채워주세요        ║
# ╚═══════════════════════════════════════════════════════╝

# ── App ──────────────────────────────────────────────────
APP_ENV=dev                  # dev | staging | prod
DEBUG=true

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trader:trader@db:5432/trader_db

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Telegram ─────────────────────────────────────────────
# @BotFather에서 봇 생성 후 토큰 입력
TELEGRAM_BOT_TOKEN=
# 허용할 텔레그램 사용자 ID (콤마 구분)
# 자신의 ID는 @userinfobot 으로 확인 가능
TELEGRAM_ALLOWED_USER_IDS=[]

# ── KakaoTalk (선택) ─────────────────────────────────────
KAKAO_REST_API_KEY=

# ── Push Notification ────────────────────────────────────
NTFY_TOPIC=stock-ta-trader
NTFY_SERVER=https://ntfy.sh

# ── External APIs ────────────────────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Korea Investment Securities
KIS_APP_KEY=
KIS_APP_SECRET=

# DART (전자공시)
DART_API_KEY=

# ── Scheduler ────────────────────────────────────────────
SCHEDULER_ENABLED=true
MARKET_PRE_SCAN_CRON=0 8 * * 1-5
MARKET_POST_REVIEW_CRON=0 16 * * 1-5

# ── Cloudflare Tunnel (선택) ─────────────────────────────
# CLOUDFLARE_TUNNEL_TOKEN=
